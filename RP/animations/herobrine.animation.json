        },
        "leftLeg": {
          "rotation": [ "math.cos(query.anim_time * 38.17 + 180) * 40.0", 0, 0 ]
        },
        "rightArm": {
          "rotation": [ "math.cos(query.anim_time * 38.17 + 180) * 40.0", 0, 0 ]
        },
        "leftArm": {
          "rotation": [ "math.cos(query.anim_time * 38.17) * 40.0", 0, 0 ]
        }
      }
    },
    "animation.herobrine.attack": {
      "loop": false,
      "animation_length": 0.5,
      "bones": {
        "rightArm": {
          "rotation": {
            "0.0": [ 0, 0, 0 ],
