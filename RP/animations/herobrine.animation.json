{
  "format_version": "1.20.20",
  "animations": {
    "animation.herobrine.idle": {
      "loop": true,
      "bones": {
        "rightArm": { "rotation": [ "math.sin(query.life_time * 76.4) * 2.86", 0, 0 ] },
        "leftArm": { "rotation": [ "math.sin(query.life_time * 76.4 + 180) * 2.86", 0, 0 ] }
      }
    },
    "animation.herobrine.walk": {
      "loop": true,
      "anim_time_update": "query.modified_distance_moved",
      "bones": {
        "rightLeg": { "rotation": [ "math.cos(query.anim_time * 38.17) * 40.0", 0, 0 ] },
        "leftLeg": { "rotation": [ "math.cos(query.anim_time * 38.17 + 180) * 40.0", 0, 0 ] },
        "rightArm": { "rotation": [ "math.cos(query.anim_time * 38.17 + 180) * 40.0", 0, 0 ] },
        "leftArm": { "rotation": [ "math.cos(query.anim_time * 38.17) * 40.0", 0, 0 ] }
      }
    },
    "animation.herobrine.quiet_stare": {
      "loop": true,
      "bones": {
        "body": { "rotation": [ "math.sin(query.life_time * 50) * 0.5", 0, 0 ] },
        "rightArm": { "rotation": [ 0, 0, 0 ] },
        "leftArm": { "rotation": [ 0, 0, 0 ] }
      }
    },
    "animation.herobrine.tilt_head": {
      "loop": true,
      "bones": {
        "head": {
          "rotation": [ "query.target_x_rotation", "query.target_y_rotation", 20.0 ]
        },
        "body": { "rotation": [ "math.sin(query.life_time * 50) * 0.5", 0, 0 ] }
      }
    },
    "animation.herobrine.look_at_target": {
      "loop": true,
      "bones": {
        "head": {
          "rotation": [ "query.target_x_rotation", "query.target_y_rotation", 0 ]
        }
      }
    },
    "animation.herobrine.slow_walk": {
      "loop": true,
      "anim_time_update": "query.modified_distance_moved",
      "bones": {
        "rightLeg": { "rotation": [ "math.cos(query.anim_time * 20.0) * 20.0", 0, 0 ] },
        "leftLeg": { "rotation": [ "math.cos(query.anim_time * 20.0 + 180) * 20.0", 0, 0 ] },
        "rightArm": { "rotation": [ "math.cos(query.anim_time * 20.0 + 180) * 10.0", 0, 0 ] },
        "leftArm": { "rotation": [ "math.cos(query.anim_time * 20.0) * 10.0", 0, 0 ] }
      }
    },
    "animation.herobrine.teleport_fade": {
      "loop": false,
      "animation_length": 1.0,
      "bones": {
        "head": { "scale": { "0.0": [ 1.0, 1.0, 1.0 ], "0.5": [ 0.5, 1.5, 0.5 ], "1.0": [ 0.0, 0.0, 0.0 ] } },
        "body": { "scale": { "0.0": [ 1.0, 1.0, 1.0 ], "0.5": [ 0.5, 1.5, 0.5 ], "1.0": [ 0.0, 0.0, 0.0 ] } },
        "rightArm": { "scale": { "0.0": [ 1.0, 1.0, 1.0 ], "0.5": [ 0.5, 1.5, 0.5 ], "1.0": [ 0.0, 0.0, 0.0 ] } },
        "leftArm": { "scale": { "0.0": [ 1.0, 1.0, 1.0 ], "0.5": [ 0.5, 1.5, 0.5 ], "1.0": [ 0.0, 0.0, 0.0 ] } },
        "rightLeg": { "scale": { "0.0": [ 1.0, 1.0, 1.0 ], "0.5": [ 0.5, 1.5, 0.5 ], "1.0": [ 0.0, 0.0, 0.0 ] } },
        "leftLeg": { "scale": { "0.0": [ 1.0, 1.0, 1.0 ], "0.5": [ 0.5, 1.5, 0.5 ], "1.0": [ 0.0, 0.0, 0.0 ] } }
      }
    },
    "animation.herobrine.attack": {
      "loop": false,
      "animation_length": 0.5,
      "bones": {
        "rightArm": {
          "rotation": {
            "0.0": [ 0, 0, 0 ],
            "0.2": [ -80, 0, 0 ],
            "0.4": [ 20, 0, 0 ],
            "0.5": [ 0, 0, 0 ]
          }
        }
      }
    }
  }
}
