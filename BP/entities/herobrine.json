{
  "format_version": "1.20.20",
  "minecraft:entity": {
    "description": {
      "identifier": "antigravity:herobrine",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false,
      "properties": {
        "antigravity:state": {
          "type": "int",
          "default": 0,
          "range": [0, 10],
          "client_sync": true
        }
      }
    },
    "component_groups": {
      "antigravity:stalking": {
        "minecraft:movement": {
          "value": 0.2
        },
        "minecraft:behavior.look_at_player": {
          "priority": 1,
          "look_distance": 64,
          "probability": 1.0
        }
      },
      "antigravity:attacking": {
        "minecraft:movement": {
          "value": 0.35
        },
        "minecraft:behavior.melee_attack": {
          "priority": 1,
          "speed_multiplier": 1.2,
          "track_target": true
        },
        "minecraft:behavior.nearest_attackable_target": {
          "priority": 2,
          "entity_types": [
            {
              "filters": { "test": "is_family", "subject": "other", "value": "player" },
              "max_dist": 64
            }
          ],
          "must_see": true
        }
      },
      "antigravity:idle": {
        "minecraft:movement": {
          "value": 0.0
        },
        "minecraft:behavior.look_at_player": {
          "priority": 2,
          "look_distance": 64,
          "probability": 1.0
        }
      }
    },
    "components": {
      "minecraft:type_family": {
        "family": [ "herobrine", "monster", "mob" ]
      },
      "minecraft:collision_box": {
        "width": 0.6,
        "height": 1.9
      },
      "minecraft:nameable": {
      },
      "minecraft:health": {
        "value": 100,
        "max": 100
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": { "test": "in_lava", "subject": "self", "operator": "==", "value": true },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:movement": {
        "value": 0.25
      },
      "minecraft:movement.basic": {
      },
      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "avoid_water": true,
        "avoid_damage_blocks": true
      },
      "minecraft:jump.static": {
      },
      "minecraft:can_climb": {
      },
      "minecraft:physics": {
      },
      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      },
      "minecraft:attack": {
        "damage": 5
      },
      "minecraft:despawn": {
        "despawn_from_distance": {}
      }
    },
    "events": {
      "minecraft:entity_spawned": {
        "add": {
          "component_groups": [
            "antigravity:idle"
          ]
        }
      },
      "antigravity:start_stalking": {
        "remove": {
          "component_groups": [
            "antigravity:idle",
            "antigravity:attacking"
          ]
        },
        "add": {
          "component_groups": [
            "antigravity:stalking"
          ]
        }
      },
      "antigravity:start_attack": {
        "remove": {
          "component_groups": [
            "antigravity:idle",
            "antigravity:stalking"
          ]
        },
        "add": {
          "component_groups": [
            "antigravity:attacking"
          ]
        }
      },
      "antigravity:stop_action": {
        "remove": {
          "component_groups": [
            "antigravity:stalking",
            "antigravity:attacking"
          ]
        },
        "add": {
          "component_groups": [
            "antigravity:idle"
          ]
        }
      }
    }
  }
}
